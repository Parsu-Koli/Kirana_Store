<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="google" content="notranslate">

    <title>@ViewData["Title"] - KiranaStoreUI</title>

    <!-- Bootstrap -->

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>

        header {
            position: relative;
            z-index: 2000;
        }

        .navbar-custom {
            position: relative;
            z-index: 1050;
        }

        .navbar-2nd {
            position: relative;
            z-index: 1000;
        }

        .profile-dropdown {
            width: 320px;
            border-radius: 15px;
            overflow: hidden;
        }

        .profile-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #198754;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .profile-avatar-large {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background: #198754;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .user-profile {
            padding: 6px 12px !important;
            border-radius: 12px;
            transition: all .3s;
        }

            .user-profile:hover {
                background: rgba(25,135,84,.1);
            }

       

            .dropdown-item:hover {
                background: #f8f9fa;
            }

        /* ===========================
           WHITE GLASS THEME
        =========================== */
        body {
            min-height: 100vh;
            margin: 0;
            padding: 0;
            background: radial-gradient(circle at top left, rgba(59,130,246,.35), transparent 35%), radial-gradient(circle at top right, rgba(236,72,153,.25), transparent 30%), radial-gradient(circle at bottom, rgba(16,185,129,.25), transparent 35%), #eef4ff;
            background-attachment: fixed;
            top: 0 !important;
        }

        /* ===========================
           HEADER
        =========================== */

        header {
            position: relative;
            z-index: 9999;
        }

        /* ===========================
           FIRST NAVBAR
        =========================== */

        

            .navbar-custom::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: inherit;
                /* background: linear-gradient( 135deg, rgba(255,255,255,.5), rgba(255,255,255,.05) ); */
                pointer-events: none;
            }

        /* ===========================
           SECOND NAVBAR
        =========================== */

        .navbar-2nd {
            background: rgba(255,255,255,.12);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255,255,255,.35);
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }

        /* ===========================
           LINKS
        =========================== */

        .nav-link {
            color: #1e293b !important;
            font-weight: 600;
            border-radius: 10px;
            transition: all .3s ease;
        }

            .nav-link:hover {
                background: rgba(255,255,255,.45);
                transform: translateY(-2px);
            }

        /* ===========================
           USER PROFILE
        =========================== */

        .user-profile {
            background: rgba(255,255,255,.25);
            border: 1px solid rgba(255,255,255,.35);
            border-radius: 14px;
            padding: 6px 12px !important;
        }

            .user-profile:hover {
                background: rgba(255,255,255,.45);
            }

        /* ===========================
           DROPDOWN
        =========================== */

        .profile-dropdown,
        .dropdown-menu {
            background: rgba(255,255,255,.45);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255,255,255,.5);
            border-radius: 18px;
            box-shadow: 0 12px 40px rgba(0,0,0,.12);
            z-index: 10000 !important;
        }

        .dropdown-item {
            border-radius: 10px;
            color: #1e293b;
            transition: .3s;
        }

            .dropdown-item:hover {
                background: rgba(255,255,255,.55);
                color: #0f172a;
            }

        /* ===========================
           SUBMENU
        =========================== */

        .submenu {
            background: rgba(255,255,255,.45);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255,255,255,.5);
            border-radius: 18px;
            z-index: 10001 !important;
        }

        /* ===========================
           PROFILE AVATAR
        =========================== */

        .profile-avatar,
        .profile-avatar-large {
            background: linear-gradient( 135deg, #60a5fa, #38bdf8 );
            color: white;
            box-shadow: 0 0 15px rgba(96,165,250,.35);
        }

        /* ===========================
           BODY CONTAINER
        =========================== */

        #Body {
            width: 98%;
            max-width: none;
            margin: 15px auto;
            background: rgba(255,255,255,.10);
            backdrop-filter: blur(30px);
            border-radius: 24px;
            box-shadow: 0 15px 40px rgba(0,0,0,.08);
            padding: 25px;
        }

        /* ===========================
           DATE
        =========================== */

        .navbar-date {
            color: #334155;
            font-size: 14px;
            font-weight: 600;
            padding-right: 15px;
        }

        /* ===========================
           LOGO TEXT
        =========================== */

        .navbar-brand,
        .navbar-brand span {
            color: #0f172a !important;
        }

        /* ===================================
           Footer
        ====================================*/

        footer {
            margin-top: 20px;
        }

        /* ===================================
        Hide Google Translate Branding
        =================================== */

        .goog-te-banner-frame.skiptranslate,
        iframe.skiptranslate {
            display: none !important;
        }

        body {
            top: 0px !important;
        }

        .goog-logo-link,
        .goog-te-gadget span,
        .goog-te-gadget-simple img {
            display: none !important;
        }

        .goog-te-gadget {
            color: transparent !important;
            font-size: 0px !important;
        }


        /* ===================================
   Transparent Google Translate
===================================*/

        .goog-te-combo {
            width: 130px !important;
            padding: 4px 6px !important;

            background: transparent !important;

            border: none !important;

            color: white !important;

            font-size: 13px !important;

            font-weight: 600 !important;

            cursor: pointer;

            outline: none !important;

            box-shadow: none !important;
        }

        /* Dropdown Arrow */

        .goog-te-combo option {
            color: black !important;
        }

        .dropend:hover > .dropdown-menu {
            display: block;
            top: 0;
            left: 100%;
            margin-top: -1px;
        }

        .dropdown-header {
            font-weight: 600;
            color: #198754;
        }

        /* Focus Effect */

        .goog-te-combo:focus {
            outline: none !important;
            box-shadow: none !important;
        }

        /* Hide Google Branding */

        .goog-logo-link,
        .goog-te-gadget span,
        .goog-te-gadget-simple img {
            display: none !important;
        }

        .goog-te-gadget {
            color: transparent !important;
            font-size: 0 !important;
        }

        .profile-dropdown {
            overflow: visible;
        }

        .submenu {
            display: none;
            position: absolute;
            top: 0;
            right: 100%;
            left: auto;
            margin-right: 10px;
            min-width: 300px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,.15);
            z-index: 9999 !important;
        }

        .dropdown-submenu:hover > .submenu {
            display: block;
        }

        .dropdown-submenu {
            position: relative;
        }

            /* This keeps submenu open even when moving cursor */
            .dropdown-submenu:hover > .submenu {
                display: block;
                animation: fadeIn 0.15s ease-in-out;
            }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateX(10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }

        }

        .glass-footer {
            width: 98%;
            margin: 20px auto 40px auto;
            background: rgba(255,255,255,.10);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-radius: 24px;
            box-shadow: 0 15px 40px rgba(0,0,0,.08);
            border: 1px solid rgba(255,255,255,.20);
            color: #0f172a;
        }


/* ===================================
   Professional Loader
===================================*/

#loader-container {
    position: fixed;
    inset: 0;

    background: rgba(25,135,84,0.15);

    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);

    z-index: 99999;

    display: flex;
    justify-content: center;
    align-items: center;
}

#loader-container.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loader {
    width: 48px;
    height: 48px;
    display: inline-block;
    position: relative;
    transform: rotate(45deg);
}

.loader::before {
    content: '';
    box-sizing: border-box;
    width: 24px;
    height: 24px;
    position: absolute;
    left: 0;
    top: -24px;
    animation: animloader 4s ease infinite;
}

.loader::after {
    content: '';
    box-sizing: border-box;
    position: absolute;
    left: 0;
    top: 0;
    width: 24px;
    height: 24px;
    background: white;
    box-shadow: 0 0 15px rgba(0,0,0,.2);
    animation: animloader2 2s ease infinite;
}

@@keyframes animloader {
    0% {
        box-shadow: 0 24px rgba(255,255,255,0),
                    24px 24px rgba(255,255,255,0),
                    24px 48px rgba(255,255,255,0),
                    0 48px rgba(255,255,255,0);
    }
    50% {
        box-shadow: 0 24px white,
                    24px 24px white,
                    24px 48px white,
                    0 48px white;
    }
    100% {
        box-shadow: 0 24px rgba(255,255,255,0),
                    24px 24px rgba(255,255,255,0),
                    24px 48px rgba(255,255,255,0),
                    0 48px rgba(255,255,255,0);
    }
}

@@keyframes animloader2 {
    0% {
        transform: translate(0,0);
    }
    25% {
        transform: translate(100%,0);
    }
    50% {
        transform: translate(100%,100%);
    }
    75% {
        transform: translate(0,100%);
    }
    100% {
        transform: translate(0,0);
    }
}
.loader-content{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
}



/* Move text upward */
.loader-content h4,
.loader-content small {
    transform: translateY(-20px);
}

#loader-container {
    transition: all .4s ease;
}

#loader-container.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}
    </style>

</head>

@{
var username = Context.Session.GetString("Username");
var role = Context.Session.GetString("Role");
var isLoggedIn = !string.IsNullOrEmpty(username);
}

<body>

<div id="loader-container">

    <div class="loader-content">

        <div class="loader"></div>

        <h4 class="fw-bold text-success mt-5 mb-1">
            Kirana Store
        </h4>

        <small class="text-muted">
