    </header>

    <!-- ===================================
         Body
    ====================================-->

    <div class="container mt-4" id="Body">

        @RenderBody()

    </div>

    <!-- ===================================
         Footer
    ====================================-->

    @* <footer class="glass-footer py-3 mt-4 mb-5">

        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">

            <div class="mb-2 mb-md-0">
                © 2026 Kirana Store
            </div>

            <div>
                <span class="me-2">Powered by</span>
                <span class="fw-bold text-success">
                    ASP.NET Core MVC
                </span>
            </div>

            <div>
                Developed By
                <span class="fw-semibold text-primary">
                    Prashant Koli
                </span>
            </div>

        </div>

    </footer> *@

    <!-- ===================================
         Google Translate
    ====================================-->

    <script type="text/javascript">

        function googleTranslateElementInit() {

            new google.translate.TranslateElement(
                {
                    pageLanguage: 'en',
                    includedLanguages: 'en,hi,mr',
                    autoDisplay: false
                },
                'google_translate_element'
            );
        }

        // =====================================
        // GET CURRENT SELECTED LANGUAGE
        // =====================================

        function getCurrentLanguage() {

            const googleDropdown =
                document.querySelector(".goog-te-combo");

            if (googleDropdown) {

                return googleDropdown.value;
            }

            return "en";
        }



        function changeTranslateText() {

            const interval = setInterval(() => {

                const selectBox =
                    document.querySelector(".goog-te-combo");

                if (selectBox) {

                    // Change default option text

                    if (selectBox.options[0]) {
                        selectBox.options[0].text = "ENG";
                    }

                    clearInterval(interval);
                }

            }, 500);
        }

        window.addEventListener("load", changeTranslateText);


    </script>

    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- ===================================
         Scripts
    ====================================-->

    <script src="https://unpkg.com/html5-qrcode"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>

document.addEventListener("DOMContentLoaded", function () {

    const loader =
        document.getElementById("loader-container");

    if (!loader) return;

    // Hide after page load
    window.addEventListener("load", function () {

        setTimeout(() => {

            loader.classList.add("hide");

        }, 500);

    });

    // Navigation links
    document
    .querySelectorAll("a.nav-link, .dropdown-item")
    .forEach(link => {

        link.addEventListener("click", function () {

            const href = this.getAttribute("href");

            // Ignore dropdown toggle
            if (!href || href === "#") {
                return;
            }

            loader.classList.remove("hide");
        });

    });

    // Form submits (Login, Register, Create Sale, etc.)
    document
        .querySelectorAll("form")
        .forEach(form => {

            form.addEventListener("submit", function () {

                if (form.checkValidity()) {

                    loader.classList.remove("hide");

                }

            });

        });

});

</script>

</body>

</html>