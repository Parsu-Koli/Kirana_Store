<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="google" content="notranslate">

    <title>@ViewData["Title"] - KiranaStoreUI</title>

    <!-- Bootstrap -->

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>

        .profile-dropdown {
            width: 320px;
            border-radius: 15px;
            overflow: hidden;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #198754;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .profile-avatar-large {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background: #198754;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .user-profile {
            padding: 6px 12px !important;
            border-radius: 12px;
            transition: all .3s;
        }

            .user-profile:hover {
                background: rgba(25,135,84,.1);
            }

        .dropdown-item {
            padding: 10px 18px;
            font-weight: 500;
        }

            .dropdown-item:hover {
                background: #f8f9fa;
            }

  
        /* ===================================
           Global Layout
        ====================================*/

        html,
        body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            top: 0px !important;
            background-color: #f8f9fa;
        }

        #Body {
            flex: 1;
        }

        /* ===================================
           Navbar
        ====================================*/

        .navbar-custom {
            background: linear-gradient(90deg, #198754, #157347);
            padding-top: 12px;
            padding-bottom: 12px;
        }

        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 20px;
        }

        .navbar-custom .nav-link {
            color: white !important;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 8px;
            transition: 0.3s;
        }

        .navbar-custom .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.15);
        }

        .navbar-custom .dropdown-toggle::after {
            margin-left: 6px;
        }

        /* ===================================
           Dropdown
        ====================================*/

        .dropdown-menu {
            border: none;
            border-radius: 14px;
            padding: 10px;
            min-width: 250px;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 10px 12px;
            transition: 0.2s;
        }

        .dropdown-item:hover {
            background-color: #f1f1f1;
        }

        /* ===================================
           Footer
        ====================================*/

        footer {
            margin-top: 20px;
        }

        /* ===================================
   Hide Google Translate Branding
===================================*/

        .goog-te-banner-frame.skiptranslate,
        iframe.skiptranslate {
            display: none !important;
        }

        body {
            top: 0px !important;
        }

        .goog-logo-link,
        .goog-te-gadget span,
        .goog-te-gadget-simple img {
            display: none !important;
        }

        .goog-te-gadget {
            color: transparent !important;
            font-size: 0px !important;
        }


        /* ===================================
   Transparent Google Translate
===================================*/

        .goog-te-combo {
            width: 130px !important;
            padding: 4px 6px !important;

            background: transparent !important;

            border: none !important;

            color: white !important;

            font-size: 13px !important;

            font-weight: 600 !important;

            cursor: pointer;

            outline: none !important;

            box-shadow: none !important;
        }

        /* Dropdown Arrow */

        .goog-te-combo option {
            color: black !important;
        }

        .dropend:hover > .dropdown-menu {
            display: block;
            top: 0;
            left: 100%;
            margin-top: -1px;
        }

        .dropdown-header {
            font-weight: 600;
            color: #198754;
        }

        /* Focus Effect */

        .goog-te-combo:focus {
            outline: none !important;
            box-shadow: none !important;
        }

        /* Hide Google Branding */

        .goog-logo-link,
        .goog-te-gadget span,
        .goog-te-gadget-simple img {
            display: none !important;
        }

        .goog-te-gadget {
            color: transparent !important;
            font-size: 0 !important;
        }

        .profile-dropdown {
            overflow: visible;
        }

        .submenu {
            display: none;
            position: absolute;
            top: 0;
            right: 100%;
            left: auto;
            margin-right: 10px;
            min-width: 300px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,.15);
            z-index: 1055;
        }

        .dropdown-submenu:hover > .submenu {
            display: block;
        }

        .dropdown-submenu {
            position: relative;
        }

            /* This keeps submenu open even when moving cursor */
            .dropdown-submenu:hover > .submenu {
                display: block;
                animation: fadeIn 0.15s ease-in-out;
            }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateX(10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }

        }

/* ===================================
   Professional Loader
===================================*/

#loader-container {
    position: fixed;
    inset: 0;

    background: rgba(25,135,84,0.15);

    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);

    z-index: 99999;

    display: flex;
    justify-content: center;
    align-items: center;
}

#loader-container.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loader {
    width: 48px;
    height: 48px;
    display: inline-block;
    position: relative;
    transform: rotate(45deg);
}

.loader::before {
    content: '';
    box-sizing: border-box;
    width: 24px;
    height: 24px;
    position: absolute;
    left: 0;
    top: -24px;
    animation: animloader 4s ease infinite;
}

.loader::after {
    content: '';
    box-sizing: border-box;
    position: absolute;
    left: 0;
    top: 0;
    width: 24px;
    height: 24px;
    background: white;
    box-shadow: 0 0 15px rgba(0,0,0,.2);
    animation: animloader2 2s ease infinite;
}

@@keyframes animloader {
    0% {
        box-shadow: 0 24px rgba(255,255,255,0),
                    24px 24px rgba(255,255,255,0),
                    24px 48px rgba(255,255,255,0),
                    0 48px rgba(255,255,255,0);
    }
    50% {
        box-shadow: 0 24px white,
                    24px 24px white,
                    24px 48px white,
                    0 48px white;
    }
    100% {
        box-shadow: 0 24px rgba(255,255,255,0),
                    24px 24px rgba(255,255,255,0),
                    24px 48px rgba(255,255,255,0),
                    0 48px rgba(255,255,255,0);
    }
}

@@keyframes animloader2 {
    0% {
        transform: translate(0,0);
    }
    25% {
        transform: translate(100%,0);
    }
    50% {
        transform: translate(100%,100%);
    }
    75% {
        transform: translate(0,100%);
    }
    100% {
        transform: translate(0,0);
    }
}
.loader-content{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
}



/* Move text upward */
.loader-content h4,
.loader-content small {
    transform: translateY(-20px);
}

#loader-container {
    transition: all .4s ease;
}

#loader-container.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}
    </style>

</head>

@{
var username = Context.Session.GetString("Username");
var role = Context.Session.GetString("Role");
var isLoggedIn = !string.IsNullOrEmpty(username);
}

<body>

<div id="loader-container">

    <div class="loader-content">

        <div class="loader"></div>

        <h4 class="fw-bold text-success mt-5 mb-1">
            Kirana Store
        </h4>

        <small class="text-muted">
            Loading Application...
        </small>

    </div>

</div>
    <!-- ===================================
         Navbar
    ====================================-->

    <header>

        <nav class="navbar navbar-expand-lg navbar-custom shadow">

            <div class="container-fluid">

                <!-- Logo -->

                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">

                    <img src="~/images/logo.jpg"
                         alt="Logo"
                         style="height:50px;width:auto;border-radius:10px;margin-right:10px;"
                         asp-append-version="true" />

                    <span>Kirana Store</span>

                </a>

                <!-- Mobile Toggle -->

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <!-- Navbar Content -->

                <div class="collapse navbar-collapse" id="navbarNav">

                    @if (isLoggedIn)
                    {
                    <ul class="navbar-nav me-auto align-items-center">

                        <!-- Billing -->

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Sale" asp-action="Create">

                                <i class="bi bi-cash-stack me-1"></i>
                                Billing Sale

                            </a>

                        </li>

                        <!-- History -->

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Sale" asp-action="Index">

                                <i class="bi bi-clock-history me-1"></i>
                                History

                            </a>

                        </li>

                        <!-- Category -->

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Category" asp-action="Index">

                                <i class="bi bi-tags me-1"></i>
                                Category

                            </a>

                        </li>

                        <!-- Stock -->

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Stock" asp-action="Chart">

                                <i class="bi bi-bar-chart-line me-1"></i>
                                Stock Chart

                            </a>

                        </li>

                        <!-- Products -->

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Product" asp-action="Index">

                                <i class="bi bi-cart-fill me-1"></i>
                                Products

                            </a>

                        </li>

                        <!-- More Dropdown -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">

                                <i class="bi bi-grid me-1"></i>
                                More

                            </a>

                            <ul class="dropdown-menu shadow">

                                <!-- Profit By Date -->

                                <li>

                                    <a class="dropdown-item" asp-controller="Sale" asp-action="ProfitByDateRange">

                                        <i class="bi bi-graph-up-arrow text-success me-2"></i>
                                        <span class="text-success">
                                            Profit By Date
                                        </span>
                                    </a>

                                </li>

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="DashBoard" asp-action="Dashboard">

                                        <i class="bi bi-speedometer2 me-1 text-success"></i>

                                        <span class="text-success">
                                            Dashboard
                                        </span>

                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="BarcodeTest" asp-action="Index">
                                        
                                        <i class="bi bi-qr-code-scan me-1 text-success"></i>
                                        <span class="text-success">
                                            Mobile Scanner
                                        </span>
                                    </a>
                                </li>

                            </ul>

                        </li>

                    </ul>
                    }

                    <!-- Right Side -->

                    <ul class="navbar-nav ms-auto">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle d-flex align-items-center user-profile href=" javascript:void(0)""
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    <div class="profile-avatar">
                                        <i class="bi bi-person-fill"></i>
                                    </div>

                                    <div class="ms-2 d-none d-md-block">
                                        <div class="fw-semibold">
                                            @User.Identity.Name
                                        </div>
                                        <small class="text-muted">
                                            Administrator
                                        </small>
                                    </div>

                                </a>

                                <ul class="dropdown-menu dropdown-menu-end profile-dropdown shadow border-0">

                                    <!-- Profile Header -->
                                    <li class="px-3 py-3 bg-light border-bottom">

                                        <div class="d-flex align-items-center">

                                            <div class="profile-avatar-large me-3">
                                                <i class="bi bi-person-fill"></i>
                                            </div>

                                            <div>
                                                <div class="fw-bold">
                                                    @User.Identity.Name
                                                </div>

                                                <small class="text-muted">
                                                    System User
                                                </small>
                                            </div>

                                        </div>

                                    </li>

                                    <!-- Settings -->
                                    <li class="dropdown-submenu position-relative">

                                        <a class="dropdown-item submenu-link"
                                           href="#">

                                            <i class="bi bi-gear me-2"></i>
                                            Settings

                                            <i class="bi bi-chevron-right float-end"></i>

                                        </a>

                                        <ul class="dropdown-menu submenu shadow border-0">

                                            <li class="p-3">

                                                <label class="fw-semibold mb-2 d-block">
                                                    Select Language
                                                </label>

                                                <div id="google_translate_element" class="bg-success"></div>

                                            </li>

                                        </ul>

                                    </li>

                                    <!-- Logo Upload -->
                                    <li class="dropdown-submenu position-relative">

                                        <a class="dropdown-item submenu-link"
                                           href="#">

                                            <i class="bi bi-image me-2"></i>
                                            Company Logo

                                            <i class="bi bi-chevron-right float-end"></i>

                                        </a>

                                        <ul class="dropdown-menu submenu shadow border-0">

                                            <li class="p-3">

                                                <form asp-controller="Logo"
                                                      asp-action="UploadLogo"
                                                      method="post"
                                                      enctype="multipart/form-data">

                                                    <input type="file"
                                                           name="logoFile"
                                                           class="form-control mb-2"
                                                           accept=".png,.jpg,.jpeg"
                                                           required />

                                                    <button class="btn btn-success w-100">
                                                        <i class="bi bi-upload me-1"></i>
                                                        Upload Logo
                                                    </button>

                                                </form>

                                            </li>

                                        </ul>

                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <!-- Register -->
                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="User"
                                           asp-action="Register">

                                            <i class="bi bi-person-plus me-2 text-success"></i>
                                            Register User

                                        </a>

                                    </li>

                                    <!-- Logout -->
                                    <li>

                                        <a class="dropdown-item text-danger"
                                           asp-controller="User"
                                           asp-action="Logout">

                                            <i class="bi bi-box-arrow-right me-2"></i>
                                            Logout

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="User"
                                   asp-action="Login">

                                    <i class="bi bi-box-arrow-in-right me-1"></i>
                                    Login

                                </a>
                            </li>
                        }
                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- ===================================
         Body
    ====================================-->

    <div class="container mt-4" id="Body">

        @RenderBody()

    </div>

    <!-- ===================================
         Footer
    ====================================-->

    <footer class="bg-success text-light py-3 border-top">

        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">

            <div class="mb-2 mb-md-0">

                © 2025 KiranaStoreUI

            </div>

            <div>

                <span class="me-2">Powered by</span>

                <span class="fw-bold text-warning">

                    ASP.NET Core MVC

                </span>

            </div>

            <div>

                Developed By

                <span class="fw-semibold text-info">

                    Prashant Koli

                </span>

            </div>

        </div>

    </footer>

    <!-- ===================================
         Google Translate
    ====================================-->

    <script type="text/javascript">

        function googleTranslateElementInit() {

            new google.translate.TranslateElement(
                {
                    pageLanguage: 'en',
                    includedLanguages: 'en,hi,mr',
                    autoDisplay: false
                },
                'google_translate_element'
            );
        }

        // =====================================
        // GET CURRENT SELECTED LANGUAGE
        // =====================================

        function getCurrentLanguage() {

            const googleDropdown =
                document.querySelector(".goog-te-combo");

            if (googleDropdown) {

                return googleDropdown.value;
            }

            return "en";
        }



        function changeTranslateText() {

            const interval = setInterval(() => {

                const selectBox =
                    document.querySelector(".goog-te-combo");

                if (selectBox) {

                    // Change default option text

                    if (selectBox.options[0]) {
                        selectBox.options[0].text = "ENG";
                    }

                    clearInterval(interval);
                }

            }, 500);
        }

        window.addEventListener("load", changeTranslateText);


    </script>

    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- ===================================
         Scripts
    ====================================-->

    <script src="https://unpkg.com/html5-qrcode"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>

document.addEventListener("DOMContentLoaded", function () {

    const loader =
        document.getElementById("loader-container");

    if (!loader) return;

    // Hide after page load
    window.addEventListener("load", function () {

        setTimeout(() => {

            loader.classList.add("hide");

        }, 500);

    });

    // Navigation links
    document
    .querySelectorAll("a.nav-link, .dropdown-item")
    .forEach(link => {

        link.addEventListener("click", function () {

            const href = this.getAttribute("href");

            // Ignore dropdown toggle
            if (!href || href === "#") {
                return;
            }

            loader.classList.remove("hide");
        });

    });

    // Form submits (Login, Register, Create Sale, etc.)
    document
        .querySelectorAll("form")
        .forEach(form => {

            form.addEventListener("submit", function () {

                if (form.checkValidity()) {

                    loader.classList.remove("hide");

                }

            });

        });

});

</script>

</body>

</html>