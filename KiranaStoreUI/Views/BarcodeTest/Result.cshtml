@model KiranaStoreUI.Models.Product

<h3>Product Found</h3>

<table class="table table-bordered">
    <tr>
        <th>Product Id</th>
        <td>@Model.ProductId</td>
    </tr>

    <tr>
        <th>Name</th>
        <td>@Model.ProductName</td>
    </tr>

    <tr>
        <th>Barcode</th>
        <td>@Model.Barcode</td>
    </tr>

    <tr>
        <th>Price</th>
        <td>@Model.SellingPrice</td>
    </tr>

    <tr>
        <th>Stock</th>
        <td>@Model.QuantityInStock</td>
    </tr>
</table>