@model KiranaStoreUI.Models.LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>

        body {
            background: #f4f6f9;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Main Card */

        .login-card {
            width: 780px;
            border-radius: 20px;
            overflow: hidden;
            background: white;
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        }

        /* Left Side */

        .left-side {
            background: linear-gradient(135deg,#16a34a,#15803d);
            color: white;
            position: relative;
            overflow: hidden;
            padding: 40px 25px;
            min-height: 520px;
        }

        /* Floating Icons */

        .floating-icon {
            position: absolute;
            color: rgba(255,255,255,0.08);
            font-size: 32px;
        }

        .icon1 {
            top: 50px;
            left: 40px;
        }

        .icon2 {
            top: 120px;
            right: 40px;
        }

        .icon3 {
            bottom: 120px;
            left: 30px;
        }

        .icon4 {
            bottom: 60px;
            right: 50px;
        }

        .icon5 {
            top: 230px;
            left: 60px;
        }

        .icon6 {
            top: 200px;
            right: 20px;
        }

        /* Logo */

        .brand-content {
            position: relative;
            z-index: 2;
            text-align: center;
            margin-top: 70px;
        }

        .logo-box {
            width: 90px;
            height: 90px;
            background: white;
            border-radius: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: auto;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

            .logo-box i {
                font-size: 45px;
                color: #16a34a;
            }

        .store-title {
            font-size: 28px;
            font-weight: 700;
            margin-top: 20px;
        }

        .store-text {
            margin-top: 12px;
            font-size: 14px;
            line-height: 1.7;
            color: #dcfce7;
        }

        /* Right Side */

        .right-side {
            padding: 45px 35px;
        }

        .welcome-title {
            font-size: 28px;
            font-weight: 700;
            color: #111827;
        }

        .welcome-subtitle {
            color: #6b7280;
            margin-bottom: 28px;
            font-size: 14px;
        }

        /* Input */

        .form-label {
            font-weight: 600;
            font-size: 14px;
        }

        .input-group {
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #d1d5db;
        }

        .input-group-text {
            background: white;
            border: none;
            color: #6b7280;
        }

        .form-control {
            border: none;
            height: 48px;
            box-shadow: none !important;
            font-size: 14px;
        }

        .input-group:focus-within {
            border-color: #16a34a;
            box-shadow: 0 0 0 0.15rem rgba(22,163,74,.15);
        }

        /* Button */

        .login-btn {
            height: 48px;
            border-radius: 10px;
            background: #16a34a;
            border: none;
            font-weight: 600;
            font-size: 15px;
        }

            .login-btn:hover {
                background: #15803d;
            }

        .small-link {
            font-size: 13px;
        }

            .small-link a {
                color: #16a34a;
                text-decoration: none;
                font-weight: 600;
            }

                .small-link a:hover {
                    text-decoration: underline;
                }

        @@media(max-width:768px) {

            .left-side {
                display: none;
            }

            .login-card {
                width: 95%;
            }

            .right-side {
                padding: 35px 22px;
            }
        }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="row g-0">

            <!-- LEFT -->

            <div class="col-md-5">

                <div class="left-side">

                    <!-- Floating Icons -->

                    <i class="bi bi-cart floating-icon icon1"></i>
                    <i class="bi bi-basket floating-icon icon2"></i>
                    <i class="bi bi-box-seam floating-icon icon3"></i>
                    <i class="bi bi-shop floating-icon icon4"></i>
                    <i class="bi bi-bag floating-icon icon5"></i>
                    <i class="bi bi-truck floating-icon icon6"></i>

                    <!-- Brand -->

                    <div class="brand-content">

                        <div class="logo-box">
                            <i class="bi bi-shop"></i>
                        </div>

                        <div class="store-title">
                            Kirana Store
                        </div>

                        <div class="store-text">
                            Manage inventory, billing,
                            products and customers easily
                            with smart dashboard tools.
                        </div>

                    </div>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="col-md-7">

                <div class="right-side">

                    <div class="welcome-title">
                        Welcome Back
                    </div>

                    <div class="welcome-subtitle">
                        Login to continue your account
                    </div>
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger text-center">
                            @TempData["ErrorMessage"]
                        </div>
                    }
                    <!-- Validation -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <form asp-action="Login" method="post">

                        <!-- Username -->

                        <div class="mb-3">

                            <label class="form-label">
                                Username
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-person"></i>
                                </span>

                                <input asp-for="Username"
                                       class="form-control"
                                       placeholder="Enter username" />

                            </div>

                            <span asp-validation-for="Username"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Password -->

                        <div class="mb-4">

                            <label class="form-label">
                                Password
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>

                                <input asp-for="Password"
                                       type="password"
                                       id="password"
                                       class="form-control"
                                       placeholder="Enter password" />

                                <span class="input-group-text"
                                      style="cursor:pointer;"
                                      onclick="togglePassword()">

                                    <i class="bi bi-eye" id="eyeIcon"></i>

                                </span>

                            </div>

                            <span asp-validation-for="Password"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Remember -->

                        <div class="d-flex justify-content-between align-items-center mb-4 small-link">

                            <div class="form-check">

                                <input class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe">

                                <label class="form-check-label"
                                       for="rememberMe">

                                    Remember me

                                </label>

                            </div>

                            <a href="#">
                                Forgot Password?
                            </a>

                        </div>

                        <!-- Button -->

                        <button type="submit"
                                class="btn login-btn text-white w-100">

                            <i class="bi bi-box-arrow-in-right"></i>
                            Login

                        </button>

                        <!-- Register -->

                        <div class="text-center mt-4 small-link">

                            Don't have an account?

                            <a href="#">
                                Register
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <!-- Scripts -->

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function togglePassword() {

            let password = document.getElementById("password");
            let eyeIcon = document.getElementById("eyeIcon");

            if (password.type === "password") {

                password.type = "text";

                eyeIcon.classList.remove("bi-eye");
                eyeIcon.classList.add("bi-eye-slash");

            }
            else {

                password.type = "password";

                eyeIcon.classList.remove("bi-eye-slash");
                eyeIcon.classList.add("bi-eye");
            }
        }

    </script>

</body>
</html>