@model KiranaStoreUI.Models.ViewModels.SaleCustomerVM

<div class="container mt-4">

    <h2 class="text-success fw-bold mb-4">➕ Add Sale & Customer</h2>

    <div class="card shadow border-0">
        <div class="card-body p-4">

            <form method="post" id="saleForm">

                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <!-- 🔥 IMPORTANT -->
                <input asp-for="Customer.CustomerId" type="hidden" />

                <div class="row">

                    <!-- SALE DETAILS -->
                    <div class="col-md-6">
                        <h4 class="text-primary mb-3">Sale Details</h4>

                        <div class="mb-3">
                            <label class="fw-bold">Invoice Number</label>
                            <input asp-for="Sale.InvoiceNumber" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Total Amount</label>
                            <input asp-for="Sale.TotalAmount" id="total"
                                   class="form-control text-end fw-bold" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Discount</label>
                            <input asp-for="Sale.Discount" id="discount"
                                   class="form-control text-end" />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Net Amount</label>
                            <input asp-for="Sale.NetAmount" id="net"
                                   class="form-control fw-bold text-success text-end" readonly />
                        </div>

                        @* <div class="mb-3">
                            <label class="fw-bold">Payment Mode</label>
                            <select asp-for="Sale.PaymentMode" class="form-select">
                                <option>Cash</option>
                                <option>UPI</option>
                                <option>Card</option>
                                <option>Udari</option>
                            </select>
                        </div> *@
                        <div class="mb-3">

                            <label class="fw-bold">
                                Payment Mode
                            </label>

                            <select asp-for="Sale.PaymentMode"
                                    id="paymentMode"
                                    class="form-select">
                            </select>

                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Sale Date</label>
                            <input asp-for="Sale.SaleDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <!-- CUSTOMER + PRODUCT -->
                    <div class="col-md-6">
                        <h4 class="text-primary mb-3">Customer Details</h4>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Customer Name
                            </label>

                            <div class="input-group shadow-sm">

                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-person-fill text-primary"></i>
                                </span>

                                <input asp-for="Customer.Name"
                                       id="customerName"
                                       class="form-control border-start-0 border-end-0 shadow-none"
                                       placeholder="Enter or speak customer name" />

                                <button type="button"
                                        class="input-group-text bg-white border-start-0 text-danger"
                                        onclick="startVoice()"
                                        style="cursor:pointer;">

                                    <i class="bi bi-mic-fill"></i>

                                </button>

                            </div>

                            <span asp-validation-for="Customer.Name"
                                  class="text-danger small">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Phone Number
                            </label>

                            <div class="input-group shadow-sm">

                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-telephone-fill text-success"></i>
                                </span>

                                <input asp-for="Customer.Phone"
                                       class="form-control border-start-0 shadow-none"
                                       placeholder="Enter customer phone number" />

                            </div>

                            <span asp-validation-for="Customer.Phone"
                                  class="text-danger small">
                            </span>

                        </div>

                        <hr />

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Search Product
                            </label>

                            <div class="input-group shadow-sm">

                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-search text-primary"></i>
                                </span>

                                <input type="text"
                                       id="productSearch"
                                       class="form-control border-start-0 shadow-none"
                                       placeholder="Search product name..." />

                            </div>

                        </div>

                        <div id="searchResult"
                             class="list-group mt-2"
                             style="display:none;"></div>

                        <hr />

                        <h6 class="fw-bold">Selected Products</h6>
                        <ul id="selectedProducts" class="list-group"></ul>
                    </div>

                </div>

                <hr />
                <button class="btn btn-success">Submit</button>
                <a href="/Sale/Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>

<script>

    const total = document.getElementById("total");
    const discount = document.getElementById("discount");
    const net = document.getElementById("net");

    let selectedProducts = [];

    // ================================
    // DISCOUNT CALCULATION
    // ================================
    discount.addEventListener("input", () => {

        const totalValue = parseFloat(total.value || 0);
        const discountValue = parseFloat(discount.value || 0);

        net.value = (totalValue - discountValue).toFixed(2);
    });

    // ================================
    // SEARCH PRODUCT
    // ================================
    document.getElementById("productSearch")
        .addEventListener("keyup", function () {

        let keyword = this.value.trim();

        // hide if small text
        if (keyword.length < 2) {
            document.getElementById("searchResult").style.display = "none";
            return;
        }

        fetch(`/Sale/SearchProduct?keyword=${keyword}`)
            .then(response => response.json())
            .then(data => {

                let box = document.getElementById("searchResult");

                box.innerHTML = "";

                // no products
                if (!data.success || data.products.length === 0) {
                    box.style.display = "none";
                    return;
                }

                box.style.display = "block";

                data.products.forEach(product => {

                    box.innerHTML += `
                        <a href="javascript:void(0)"
                           class="list-group-item list-group-item-action"
                           onclick="addProduct(
                               ${product.productId},
                               '${product.productName}',
                               ${product.sellingPrice}
                           )">

                            <div class="d-flex justify-content-between">
                                <span>${product.productName}</span>
                                <strong>₹${product.sellingPrice}</strong>
                            </div>

                        </a>
                    `;
                });
            });
    });

    // ================================
    // ADD PRODUCT
    // ================================
    function addProduct(id, name, price) {

        // already exists
        let exists = selectedProducts.find(x => x.id === id);

        if (exists) {
            exists.qty += 1;
        }
        else {

            selectedProducts.push({
                id: id,
                name: name,
                price: price,
                qty: 1,
                unit: "Kg"
            });
        }

        renderProducts();

        document.getElementById("searchResult").style.display = "none";

        document.getElementById("productSearch").value = "";
    }

    // ================================
    // CALCULATE ITEM TOTAL
    // ================================
    function calculateItemTotal(product) {

        let quantity = product.qty;

        // convert gram to kg
        if (product.unit === "Gram") {
            quantity = quantity / 1000;
        }

        return quantity * product.price;
    }

    // ================================
    // RENDER PRODUCTS
    // ================================
    function renderProducts() {

        let ul = document.getElementById("selectedProducts");

        ul.innerHTML = "";

        let grandTotal = 0;

        selectedProducts.forEach(product => {

            let itemTotal = calculateItemTotal(product);

            grandTotal += itemTotal;

                ul.innerHTML += `

    <li class="list-group-item shadow-sm border-0 mb-3 rounded">

        <div class="d-flex justify-content-between align-items-center">

            <div>
                <h6 class="mb-1 fw-bold">
                    ${product.name}
                </h6>

                <small class="text-muted">
                    ₹${product.price}
                </small>
            </div>

            <button type="button"
                    class="btn btn-outline-danger btn-sm rounded-circle"
                    onclick="removeProduct(${product.id})">

                <i class="bi bi-trash"></i>

            </button>

        </div>

        <div class="row mt-3 align-items-center">

            <!-- Quantity Buttons -->

            <div class="col-md-6">

                <div class="d-flex align-items-center gap-2">

                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            onclick="decreaseQty(${product.id})">

                        <i class="bi bi-dash-lg"></i>

                    </button>

                    <span class="fw-bold fs-5 px-2">
                        ${product.qty}
                    </span>

                    <button type="button"
                            class="btn btn-outline-success btn-sm"
                            onclick="increaseQty(${product.id})">

                        <i class="bi bi-plus-lg"></i>

                    </button>

                </div>

            </div>

            <!-- Unit -->

            <div class="col-md-3">

                <select class="form-select form-select-sm"
                        onchange="changeUnit(${product.id}, this.value)">

                    <option value="Kg"
                        ${product.unit === "Kg" ? "selected" : ""}>
                        Kg
                    </option>

                    <option value="Gram"
                        ${product.unit === "Gram" ? "selected" : ""}>
                        Gram
                    </option>

                    <option value="Pice"
                        ${product.unit === "Pice" ? "selected" : ""}>
                        Piece
                    </option>

                </select>

            </div>

            <!-- Total -->

            <div class="col-md-3 text-end">

                <strong class="text-success">
                    ₹${itemTotal.toFixed(2)}
                </strong>

            </div>

        </div>

    </li>
    `;
        });

        total.value = grandTotal.toFixed(2);

        const discountValue = parseFloat(discount.value || 0);

        net.value = (grandTotal - discountValue).toFixed(2);
    }
        function increaseQty(id) {

        let product = selectedProducts.find(x => x.id === id);

        if (product) {

            product.qty += 1;

            renderProducts();
        }
    }

    function decreaseQty(id) {

        let product = selectedProducts.find(x => x.id === id);

        if (product && product.qty > 1) {

            product.qty -= 1;

            renderProducts();
        }
    }

    // ================================
    // FORM SUBMIT
    // ================================
    document.getElementById("saleForm")
        .addEventListener("submit", function (e) {

        // stop if no product
        if (selectedProducts.length === 0) {

            alert("Please add at least one product");

            e.preventDefault();

            return;
        }

        // remove old hidden inputs
        document.querySelectorAll(".sale-hidden")
            .forEach(x => x.remove());

        // create hidden inputs
        selectedProducts.forEach((product, index) => {

            let qty = product.qty;

            // gram convert
            if (product.unit === "Gram") {
                qty = qty / 1000;
            }

            // total
            let itemTotal = qty * product.price;

            this.appendChild(
                createHidden(
                    `Sale.SaleItems[${index}].ProductId`,
                    product.id
                )
            );

            this.appendChild(
                createHidden(
                    `Sale.SaleItems[${index}].Quantity`,
                    qty
                )
            );

            this.appendChild(
                createHidden(
                    `Sale.SaleItems[${index}].Price`,
                    product.price
                )
            );

            this.appendChild(
                createHidden(
                    `Sale.SaleItems[${index}].Total`,
                    itemTotal
                )
            );
        });
    });

    // ================================
    // CREATE HIDDEN INPUT
    // ================================
    function createHidden(name, value) {

        let input = document.createElement("input");

        input.type = "hidden";

        input.name = name;

        input.value = value;

        input.classList.add("sale-hidden");

        return input;
    }

        function startVoice() {

        // browser support
        const SpeechRecognition =
            window.SpeechRecognition ||
            window.webkitSpeechRecognition;

        if (!SpeechRecognition) {

            alert("Speech Recognition not supported");

            return;
        }

        const recognition = new SpeechRecognition();

        recognition.lang = "en-IN";

        recognition.start();

        recognition.onresult = function (event) {

            let text =
                event.results[0][0].transcript;

            document.getElementById("customerName").value = text;
        };

        recognition.onerror = function () {

            alert("Voice recognition failed");
        };
    }

    // =====================================
    // PAYMENT MODES LANGUAGE WISE
    // =====================================

    const paymentModes = {

        // English
        en: [
            { text: "Cash", value: "Cash" },
            { text: "UPI", value: "UPI" },
            { text: "Card", value: "Card" },
            { text: "Udari", value: "Udari" }
        ],

        // Marathi
        mr: [
            { text: "रोख", value: "Cash" },
            { text: "यूपीआय", value: "UPI" },
            { text: "कार्ड", value: "Card" },
            { text: "उधारी", value: "Udari" }
        ],

        // Hindi
        hi: [
            { text: "नकद", value: "Cash" },
            { text: "यूपीआई", value: "UPI" },
            { text: "कार्ड", value: "Card" },
            { text: "उधारी", value: "Udari" }
        ]
    };

    // =====================================
    // LOAD PAYMENT MODES
    // =====================================

    function loadPaymentModes() {

        const paymentDropdown =
            document.getElementById("paymentMode");

        if (!paymentDropdown)
            return;

        // get google translate dropdown
        const googleDropdown =
            document.querySelector(".goog-te-combo");

        let currentLanguage = "en";

        if (googleDropdown) {

            currentLanguage =
                googleDropdown.value || "en";
        }

        paymentDropdown.innerHTML = "";

        const modes =
            paymentModes[currentLanguage]
            || paymentModes["en"];

        modes.forEach(mode => {

            paymentDropdown.innerHTML += `
                <option value="${mode.value}">
                    ${mode.text}
                </option>
            `;
        });
    }

    // =====================================
    // INITIAL LOAD
    // =====================================

    setTimeout(() => {

        loadPaymentModes();

    }, 2000);

    // =====================================
    // AUTO LANGUAGE CHANGE DETECT
    // =====================================

    setInterval(() => {

        loadPaymentModes();

    }, 2000);

</script>