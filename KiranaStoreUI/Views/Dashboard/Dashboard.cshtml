@{
    ViewData["Title"] = "Dashboard";
    var totalSalesAmount = ViewBag.TotalSalesAmount ?? 0;
    var totalSales = ViewBag.TotalSales ?? 0;
    var totalCustomers = ViewBag.TotalCustomers ?? 0;
    var totalProfit = ViewBag.TotalProfit ?? 0;
    var salesOverview = ViewBag.SalesOverview ?? new List<dynamic>();
    var salesByPaymentMode = ViewBag.SalesByPaymentMode ?? new List<dynamic>();
    var recentSales = ViewBag.RecentSales as List<KiranaStoreUI.Models.Sale> ?? new List<KiranaStoreUI.Models.Sale>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4">
    <h2 class="text-center">Kirana Store Dashboard</h2>

    <!-- Overview Cards -->
    <div class="row text-center my-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Total Sales</h5>
                    <h3>₹@totalSalesAmount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5>Total Orders</h5>
                    <h3>@totalSales</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5>Total Customers</h5>
                    <h3>@totalCustomers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5>Total Profit</h5>
                    <h3>₹@totalProfit</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales Overview and Payment Mode -->
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5>Sales Overview (Last 7 Days)</h5>
                    <canvas id="salesOverviewChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Sales by Payment Mode</h5>
                    <canvas id="paymentModeChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Sales -->
    <div class="row mt-4">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <h5>Recent Sales</h5>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Invoice</th>
                                <th>Customer</th>
                                <th>Amount</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentSales.Any())
                            {
                                foreach (var sale in recentSales)
                                {
                                    <tr>
                                        <td>@sale.InvoiceNumber</td>
                                        <td>@(sale.Customer?.Name ?? "N/A")</td>
                                        <td>₹@sale.NetAmount</td>
                                        <td>@sale.SaleDate.ToString("dd-MM-yyyy")</td>
                                        <td>Completed</td> <!-- Replace Status with a placeholder or remove this column -->
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No recent sales found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const salesOverview = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesOverview));
        const salesByPaymentMode = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByPaymentMode));

        // Sales Overview Chart
        const salesOverviewLabels = salesOverview.map(s => s.Date);
        const salesOverviewData = salesOverview.map(s => s.TotalSales);

        new Chart(document.getElementById('salesOverviewChart'), {
            type: 'line',
            data: {
                labels: salesOverviewLabels,
                datasets: [{
                    label: 'Sales',
                    data: salesOverviewData,
                    borderColor: '#007bff',
                    backgroundColor: 'rgba(0, 123, 255, 0.2)',
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    title: {
                        display: true,
                        text: 'Sales Overview (Last 7 Days)'
                    }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Sales by Payment Mode Chart
        const paymentModeLabels = salesByPaymentMode.map(s => s.PaymentMode);
        const paymentModeData = salesByPaymentMode.map(s => s.Count);

        new Chart(document.getElementById('paymentModeChart'), {
            type: 'doughnut',
            data: {
                labels: paymentModeLabels,
                datasets: [{
                    data: paymentModeData,
                    backgroundColor: ['#28a745', '#007bff', '#ffc107', '#dc3545']
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    title: {
                        display: true,
                        text: 'Sales by Payment Mode'
                    }
                }
            }
        });
    </script>
}